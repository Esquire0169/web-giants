# Lead form submission target.
# Without attachments: JSON POST. With files: multipart/form-data (field "attachment").
#   Formspree:  https://formspree.io/f/<form-id>
#   Webhook:    https://hooks.example.com/leads
#   Custom API: https://api.webgiants.studio/leads
# When unset, the form completes locally and logs a warning to the console.
VITE_LEAD_ENDPOINT=

# Public studio contacts (shown in header / contact / footer)
VITE_CONTACT_EMAIL=hello@webgiants.studio
VITE_CONTACT_PHONE=+74951204567
VITE_CONTACT_PHONE_DISPLAY=+7 (495) 120-45-67
# Telegram usernames without @
VITE_TG_CHANNEL=webgiants
VITE_TG_ACCOUNT=webgiants_hello
